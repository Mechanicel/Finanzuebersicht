# MongoDB
# Optionaler URI-Override. Wenn gesetzt, wird diese URI unverändert verwendet.
# Wenn leer, wird die URI aus den Variablen darunter gebaut.
MONGO_URI=
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB_NAME=finanzuebersicht
MONGO_USERNAME=finanzuebersicht
MONGO_PASSWORD=change-me-in-.env
MONGO_AUTH_SOURCE=admin
MONGO_PERSON_COLLECTION=personen
MONGO_BANK_COLLECTION=banken
MONGO_ACCOUNT_TYPE_COLLECTION=kontotypen
MONGO_MARKETDATA_COLLECTION=marketdata_cache

# Frontend seed / migration sources
FRONTEND_SEED_PERSONEN_FILE=FrontendService/seeds/personen.json
FRONTEND_SEED_BANKEN_FILE=FrontendService/seeds/banken.json
FRONTEND_SEED_KONTOTYPEN_FILE=FrontendService/seeds/kontotypen.json

# markedataservice
MARKETDATA_BASE_URL=http://127.0.0.1:5000
MARKETDATA_HOST=0.0.0.0
MARKETDATA_PORT=5000

# Logging
# error = nur Fehler
# debug = eigene Debug-Infos, Drittanbieter ruhig
# trace = fast alles
LOG_VERBOSITY=debug
