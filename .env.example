# Globale Service-Konventionen
APP_ENV=dev
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# Request/Correlation IDs werden automatisch gesetzt,
# können aber per Header überschrieben werden:
# X-Request-ID
# X-Correlation-ID

# Service-spezifische App-Namen (optional Überschreibung je Prozess)
API_GATEWAY_APP_NAME=api-gateway
MASTERDATA_SERVICE_APP_NAME=masterdata-service
PERSON_SERVICE_APP_NAME=person-service
ACCOUNT_SERVICE_APP_NAME=account-service
PORTFOLIO_SERVICE_APP_NAME=portfolio-service
MARKETDATA_SERVICE_APP_NAME=marketdata-service
ANALYTICS_SERVICE_APP_NAME=analytics-service

# MongoDB (person-service)
MONGO_URI=
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DATABASE=finanzuebersicht
MONGO_USER=
MONGO_PASSWORD=
MONGO_AUTH_SOURCE=admin
MONGO_PERSON_COLLECTION=persons
MONGO_ASSIGNMENT_COLLECTION=person_bank_assignments
MONGO_ALLOWANCE_COLLECTION=tax_allowances

# marketdata-service Search (OpenFIGI)
# Instrumentsuche läuft über OpenFIGI, Markt-/Preisdaten weiterhin über yfinance.
OPENFIGI_BASE_URL=https://api.openfigi.com/v3
OPENFIGI_API_KEY=
OPENFIGI_REQUEST_TIMEOUT_SECONDS=6.0
OPENFIGI_REQUEST_RETRIES=2
OPENFIGI_REQUEST_BACKOFF_FACTOR=0.3
OPENFIGI_SEARCH_RESULT_LIMIT=20
OPENFIGI_SEARCH_DEFAULT_MARKET_SEC_DES=
